# ========================================
# SOAR 系统配置文件
# 复制此文件为 .env 并修改配置
# cp .env.example .env
# ========================================

# ---- 基础配置 ----
SOAR_DB_PATH=data/soar.db
RISK_BLOCK_THRESHOLD=70
SIMULATED_LATENCY_MS=120

# ---- JWT 认证（生产环境务必修改！）----
JWT_SECRET_KEY=change-me-to-a-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# ---- AI 模型配置（推荐通过网页端 Settings 页面配置）----
# 以下为 fallback 配置，网页端配置优先
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4.1

# ---- 威胁情报 API Keys ----
VIRUSTOTAL_API_KEY=
ABUSEIPDB_API_KEY=

# ---- 邮件通知 ----
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TO=admin@company.com

# ---- Slack 通知 ----
SLACK_WEBHOOK_URL=

# ---- 告警源 ----
SYSLOG_PORT=514
WAZUH_API_URL=
WAZUH_API_USER=
WAZUH_API_PASSWORD=
SURICATA_EVE_LOG=
