# SOAR 环境变量配置模板
# 复制为 .env 并填写: cp .env.example .env
# .env 文件不会被上传到 Git

SOAR_DB_PATH=data/soar.db
RISK_BLOCK_THRESHOLD=70
JWT_SECRET_KEY=change-me-to-a-random-string
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1
VIRUSTOTAL_API_KEY=
ABUSEIPDB_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TO=
SLACK_WEBHOOK_URL=
SYSLOG_PORT=514
WAZUH_API_URL=
WAZUH_API_USER=
WAZUH_API_PASSWORD=
SURICATA_EVE_LOG=
CORS_ORIGINS=http://localhost:5173,http://localhost:8000
