# ===== SOAR 平台环境变量配置 =====
# 复制此文件为 .env 并填入实际值

# ---- JWT 认证密钥（必填！） ----
# 生产环境必须设置一个强随机字符串
# 生成方法: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=change-me-to-a-random-string

# ---- 数据库路径 ----
# SOAR_DB_PATH=data/soar.db

# ---- 风险阻断阈值 (0-100) ----
# RISK_BLOCK_THRESHOLD=70

# ---- 威胁情报 API Keys ----
# VirusTotal: https://www.virustotal.com/gui/my-apikey
# VIRUSTOTAL_API_KEY=
# AbuseIPDB: https://www.abuseipdb.com/account/api
# ABUSEIPDB_API_KEY=

# ---- LLM 模型 ----
# OpenAI 兼容 API（通过网页 Settings 页面配置更方便）
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1

# ---- 邮件通知 (SMTP) ----
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=
# SMTP_TO=

# ---- Slack 通知 ----
# SLACK_WEBHOOK_URL=

# ---- 告警源 ----
# SYSLOG_PORT=514
# WAZUH_API_URL=
# WAZUH_API_USER=
# WAZUH_API_PASSWORD=
# SURICATA_EVE_LOG=

# ---- CORS ----
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ---- RAG 引擎 ----
# EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# CHROMADB_PATH=data/chromadb
